# Perfil Aliare — variables públicas para deploy_aliare.sh / local.
# Copiar a .env.aliare o agregar al .env con sufijo _ALIARE.
# Secrets (contraseñas/claves): Secret Manager *_ALIARE vía ./deploy_aliare.sh --setup-secrets

FACTURIA_ODOO_PROFILE=aliare

# MySQL FacturIA (defaults en deploy_aliare.sh; password solo como secret)
DB_HOST_MYSQL=167.250.5.17
DB_PORT_MYSQL=3306
DB_USER_MYSQL=sudataco_gestion
DB_NAME_MYSQL=sudataco_app

ODOO_BASE_URL_ALIARE=https://testct.aliare.com.ar
# No usar /xmlrpc/2/common acá; la app arma XML-RPC sola. Dejar vacío o /jsonrpc
ODOO_ENDPOINT_ALIARE=
ODOO_DB_ALIARE=staging-ejtngefwqs.cloudpepper.site
# Email del usuario Odoo (no el uid numérico)
ODOO_USER_ALIARE=conexion@sudata.com.ar
# Opcional si conocés el uid numérico (si no, se obtiene al autenticar)
# ODOO_USER_ID_ALIARE=10

# NO poner acá (van como secrets *_ALIARE en GCP o en deploy --setup-secrets):
# ODOO_PASSWORD_ALIARE, ODOO_API_KEY_ALIARE
# DB_PASSWORD_ALIARE, DB_PASSWORD_MYSQL_ALIARE

# Postgres padrón (mismo servidor que Dinner si comparten histórico).
# La contraseña va como secret DB_PASSWORD_ALIARE → DB_PASSWORD en GCP.
DB_HOST=vps-4657831-x.dattaweb.com
DB_PORT=5432
DB_USER=sudata_owner
DB_NAME=sudata
DB_TABLE_NAME=view_padron_facturia
DB_TABLE_NAME_TAXES=view_padron_facturia_actualizado

# Si no completás lo anterior, deploy_aliare.sh también lee las vars DB_* del .env local.

# Padrón: en perfil aliare usa facturas Odoo antes que vista Postgres (Dinner)
# PADRON_SOURCE=odoo,postgres
