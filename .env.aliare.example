# Perfil Aliare — variables públicas para deploy_aliare.sh / matching-ui-odoo multi-tenant.
# Copiar a .env.aliare. Los secrets NO van en este archivo (Secret Manager, proyecto fudo-481618).
#
# URL: ?odoo_profile=aliare (empresa sigue siendo solo filtro MySQL FacturIA).

# ── MySQL FacturIA ──────────────────────────────────────────────────────────
DB_HOST_MYSQL=167.250.5.17
DB_PORT_MYSQL=3306
DB_USER_MYSQL=sudataco_gestion
# DB_NAME_MYSQL=   opcional (queries usan sudataco_facturia.*)

# ── Odoo Aliare (públicas) ──────────────────────────────────────────────────
ODOO_BASE_URL_ALIARE=https://testct.aliare.com.ar
ODOO_ENDPOINT_ALIARE=/jsonrpc
# ODOO_DB_ALIARE=   opcional (auth / db.list resuelve)
ODOO_DB_ALIARE=staging-ejtngefwqs.cloudpepper.site
ODOO_USER_ALIARE=conexion@sudata.com.ar
# ODOO_USER_ID_ALIARE=10

# ── Postgres padrón ─────────────────────────────────────────────────────────
DB_HOST=vps-4657831-x.dattaweb.com
DB_PORT=5432
DB_USER=sudata_owner
# DB_NAME=         opcional (default DB_USER)
DB_NAME=sudata
DB_TABLE_NAME=view_padron_facturia
DB_TABLE_NAME_TAXES=view_padron_facturia_actualizado

# ── Secrets en GCP (proyecto fudo-481618) — NO commitear valores ───────────
# Secret Manager          → env en Cloud Run
# DB_PASSWORD_ALIARE      → DB_PASSWORD
# DB_PASSWORD_MYSQL_ALIARE → DB_PASSWORD_MYSQL
# ODOO_PASSWORD_ALIARE  → ODOO_PASSWORD_ALIARE
# ODOO_API_KEY_ALIARE   → ODOO_API_KEY_ALIARE
#
# matching-ui-odoo (multi-tenant): vars públicas arriba + secrets Aliare montados.
# matching-ui-aliare (solo Aliare): FACTURIA_ODOO_PROFILE=aliare + mismos secrets.
#
# Alta/rotación: ./deploy_aliare.sh --setup-secrets
# Verificar:     ./deploy_aliare.sh --check-secrets

# Opcional solo deploy dedicado Aliare:
# FACTURIA_ODOO_PROFILE=aliare
# PADRON_SOURCE=odoo,postgres
