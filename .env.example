# PostgreSQL (padrón) — DB_NAME opcional: default DB_USER o única base accesible
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
# DB_NAME=
DB_TABLE_NAME=view_padron_facturia
DB_TABLE_NAME_TAXES=view_padron_facturia_actualizado
DB_SCHEMA=public

# MySQL (procesos FacturIA) — DB_NAME_MYSQL opcional (queries con schema.tabla)
DB_HOST_MYSQL=
DB_PORT_MYSQL=3306
DB_USER_MYSQL=
DB_PASSWORD_MYSQL=
# DB_NAME_MYSQL=
# PROCESS_SCHEMA=sudataco_facturia   # default prod; dev/local staging: sudataco_staging

# Odoo Dinner (catálogos, health e import de facturas)
ODOO_BASE_URL=
ODOO_ENDPOINT=/jsonrpc
ODOO_DB=
# Opcional: si hay una sola base, auth con ODOO_USER/ODOO_PASSWORD, o host = nombre de base.
ODOO_USER_ID=
ODOO_USER=
ODOO_PASSWORD=
# Opcional: se usa solo si ODOO_PASSWORD está vacía (mismo rol en RPC)
ODOO_API_KEY=

# Odoo Cloud Sudata (?odoo_cloud=1) — ver .env.sudata.example
# ODOO_BASE_URL_SUDATA=
# ODOO_ENDPOINT_SUDATA=/jsonrpc
# ODOO_DB_SUDATA=
# ODOO_USER_SUDATA=
# ODOO_PASSWORD_SUDATA=
# ODOO_API_KEY_SUDATA=

# Opcionales
PADRON_FUZZY_MIN_SCORE=72
# Perfil Odoo del que vienen los tax id del padrón Postgres (default=Dinner).
# Mapeo empresa → perfil (override opcional): EMPRESA_ODOO_PROFILE_MAP=1=default,4=aliare,7=sudata
# Usar cuando el padrón PG tiene ids de otro tenant; el remapeo resuelve al perfil activo del request.
# PADRON_TAX_SOURCE_PROFILE=default
ODOO_CATALOG_CACHE_TTL=600
DEFAULT_JOURNAL_NAME=
DEFAULT_RUBRO_NAME=
