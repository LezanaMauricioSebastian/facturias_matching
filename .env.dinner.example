# Perfil Dinner — variables públicas para deploy.sh / matching-ui-odoo.
# Copiar a .env.dinner. Los secrets NO van en este archivo (Secret Manager, proyecto fudo-481618).
#
# Servicios Cloud Run:
#   matching-ui-odoo (./deploy.sh)     → Dinner prod + Aliare Central Ticket
#   odoo-dev         (./deploy.sh --dev) → Dinner TEST + Aliare testct
#
# URL: ?odoo_profile=default u omitido (empresa sigue siendo solo filtro MySQL FacturIA).
# Odoo Cloud Sudata: ?odoo_cloud=1 o ?odoo_profile=sudata (ver .env.sudata.example).

# ── MySQL FacturIA ──────────────────────────────────────────────────────────
DB_HOST_MYSQL=167.250.5.17
DB_PORT_MYSQL=3306
DB_USER_MYSQL=sudataco_admin
# DB_NAME_MYSQL=   opcional (queries usan PROCESS_SCHEMA.*)
# PROCESS_SCHEMA=sudataco_facturia   # default prod
# odoo-dev (./deploy.sh --dev) inyecta PROCESS_SCHEMA=sudataco_staging y DB_USER_MYSQL=sudataco_admin

# ── Odoo Dinner prod (matching-ui-odoo) — deploy.sh inyecta estos valores ───
ODOO_BASE_URL=https://dinner.odoo.com
ODOO_ENDPOINT=/jsonrpc
ODOO_DB=somoswilox-dinner-main-20779820
ODOO_USER=fundacion.sud@gmail.com

# ── Odoo Dinner TEST (odoo-dev) — solo referencia; deploy.sh --dev los aplica ─
# ODOO_BASE_URL=https://dinner-test.odoo.com
# ODOO_USER_ID=55
# ODOO_USER=fundacion.sud@gmail.com
# (sin ODOO_DB: se resuelve automáticamente con credenciales)

# ── Odoo Aliare prod (matching-ui-odoo, ?odoo_profile=aliare) ────────────────
ODOO_BASE_URL_ALIARE=https://centralticket.aliare.com.ar
ODOO_ENDPOINT_ALIARE=/jsonrpc
ODOO_DB_ALIARE=centralticket
ODOO_USER_ALIARE=conexion@sudata.com.ar

# ── Odoo Aliare testct (odoo-dev) — deploy.sh --dev ─────────────────────────
# ODOO_BASE_URL_ALIARE=https://testct.aliare.com.ar
# ODOO_DB_ALIARE=staging-ejtngefwqs.cloudpepper.site

# ── Postgres padrón ─────────────────────────────────────────────────────────
DB_HOST=vps-4657831-x.dattaweb.com
DB_PORT=5432
DB_USER=sudata_owner
# DB_NAME=         opcional (default DB_USER)
DB_NAME=sudata
DB_TABLE_NAME=view_padron_facturia
DB_TABLE_NAME_TAXES=view_padron_facturia_actualizado

# ── Secrets en GCP (proyecto fudo-481618) — NO commitear valores ───────────
# Secret Manager          → env en Cloud Run
# DB_PASSWORD_DINNER      → DB_PASSWORD
# DB_PASSWORD_MYSQL_DINNER → DB_PASSWORD_MYSQL
# ODOO_PASSWORD_DINNER  → ODOO_PASSWORD (matching-ui-odoo, Dinner prod)
# ODOO_API_KEY_DINNER   → ODOO_API_KEY (matching-ui-odoo, Dinner prod)
# ODOO_PASSWORD_TEST    → ODOO_PASSWORD (odoo-dev, Dinner TEST)
# ODOO_API_KEY_TEST     → ODOO_API_KEY (odoo-dev, Dinner TEST)
# ODOO_PASSWORD_ALIARE  → ODOO_PASSWORD_ALIARE (Central Ticket prod / testct dev)
# ODOO_API_KEY_ALIARE   → ODOO_API_KEY_ALIARE (solo odoo-dev / local; no en prod Central Ticket)
#
# matching-ui-odoo: Dinner prod + Central Ticket (?odoo_profile=aliare).
# odoo-dev:         Dinner TEST + testct (?odoo_profile=aliare).
#
# Alta/rotación: ./deploy.sh --setup-secrets
# Verificar:     ./deploy.sh --check-secrets

# Opcional solo deploy dedicado Dinner:
# FACTURIA_ODOO_PROFILE=default
# PADRON_SOURCE=odoo,postgres
