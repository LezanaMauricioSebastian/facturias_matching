# Perfil Odoo Cloud Sudata — variables públicas para deploy multi-tenant / local.
# Copiar a .env o combinar con .env.dinner. Los secrets NO van en este archivo.
#
# URL UI/API: ?odoo_cloud=1 o ?odoo_profile=sudata (empresa = filtro MySQL FacturIA).

# ── MySQL FacturIA (mismo que Dinner / Aliare) ───────────────────────────────
DB_HOST_MYSQL=167.250.5.17
DB_PORT_MYSQL=3306
DB_USER_MYSQL=sudataco_gestion

# ── Odoo Cloud Sudata (públicas) ─────────────────────────────────────────────
ODOO_BASE_URL_SUDATA=https://sudata.odoo.com
ODOO_ENDPOINT_SUDATA=/jsonrpc
ODOO_DB_SUDATA=sudata
ODOO_USER_SUDATA=jmfernandez@sudata.co
# ODOO_USER_ID_SUDATA=

# ── Postgres padrón ───────────────────────────────────────────────────────────
DB_HOST=vps-4657831-x.dattaweb.com
DB_PORT=5432
DB_USER=sudata_owner
DB_NAME=sudata
DB_TABLE_NAME=view_padron_facturia
DB_TABLE_NAME_TAXES=view_padron_facturia_actualizado

# ── Secrets en GCP — NO commitear valores ─────────────────────────────────────
# ODOO_PASSWORD_SUDATA  → runtime (o PASSWORD_SUDATA en .env local)
# ODOO_API_KEY_SUDATA   → runtime (o API_KEY_SUDATA en .env local)
#
# Nombres legacy en .env local (fallback en código):
# URL_SUDATA, DB_SUDATA, USERNAME_SUDATA, PASSWORD_SUDATA, API_KEY_SUDATA
#
# Deploy dedicado Sudata (opcional):
# FACTURIA_ODOO_PROFILE=sudata
# PADRON_SOURCE=odoo,postgres
